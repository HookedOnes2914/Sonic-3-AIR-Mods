include config

global u8 TimesHurt
global u8 Saved.HealthCount
global u8 Add.HealthCount

function void Debug()
{
	debugLog(TimesHurt)
	debugLog(Config.HealthCount)
	debugLog(Config.TotalHealthCount)
	debugLog(Add.HealthCount)
}

// Initialize health count when spawning
function void Standalone.onLevelStart()
{
	if Config.HealthCount > Config.TotalHealthCount
	{
		Config.HealthCount = Config.TotalHealthCount
	}
	
	TimesHurt = 0
	Config.HealthCount = Config.HealthCount - Add.HealthCount
	Add.HealthCount = 0
	base.Standalone.onLevelStart()
}

function void Standalone.onLevelFinished()
{
	if Config.HealthCount > Config.TotalHealthCount
	{
		Config.HealthCount = Config.TotalHealthCount
	}
	
	TimesHurt = 0
	Config.HealthCount = Config.HealthCount - Add.HealthCount
	Add.HealthCount = 0
	base.Standalone.onLevelFinished()
}

function void Standalone.onRestartLevel()
{
	if Config.HealthCount > Config.TotalHealthCount
	{
		Config.HealthCount = Config.TotalHealthCount
	}

	TimesHurt = 0
	Config.HealthCount = Config.HealthCount - Add.HealthCount
	Add.HealthCount = 0
	base.Standalone.onRestartLevel()
}

function void Standalone.onRestartAtCheckpoint()
{
	if Config.HealthCount > Config.TotalHealthCount
	{
		Config.HealthCount = Config.TotalHealthCount
	}

	TimesHurt = 0
	Config.HealthCount = Config.HealthCount - Add.HealthCount
	base.Standalone.onRestartAtCheckpoint()
}
